/**
 * Запрос кода заказа у пользователя
 */
function promptOrderCode(title) {
  const ui = SpreadsheetApp.getUi();
  const response = ui.prompt(title, 'Введите код заказа:', ui.ButtonSet.OK_CANCEL);
  
  if (response.getSelectedButton() !== ui.Button.OK) {
    return null;
  }
  
  const orderCode = response.getResponseText().trim();
  if (!orderCode) {
    showErrorAlert('Вы не ввели код заказа.');
    return null;
  }
  
  return orderCode;
}

