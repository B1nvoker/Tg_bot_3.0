/**
 * Отображение информации о выбранных заказах (С ДАТОЙ ДОСТАВКИ И КАТЕГОРИЕЙ)
 */
function showSelectedOrdersInfo() {
  try {
    const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Заказы');
    const ui = SpreadsheetApp.getUi();
    
    const selectedRange = sheet.getActiveRange();
    if (!selectedRange) {
      ui.alert('❌ Нет выделения');
      return;
    }
    
    const startRow = selectedRange.getRow();
    const rowCount = selectedRange.getNumRows();
    
    const allData = sheet.getDataRange().getValues();
    const ordersMap = {};
    
    for (let i = startRow - 1; i < startRow - 1 + rowCount; i++) {
      const row = allData[i];
      
      const phone = normalizePhone(row[ONLINER_CONFIG.SHEET_COLUMNS.CLIENT_PHONE]);
      if (!phone) continue;
      
      // Форматируем дату доставки
      const dateValue = row[ONLINER_CONFIG.SHEET_COLUMNS.DATE_DELIVERY];
      const deliveryDate = dateValue instanceof Date
        ? Utilities.formatDate(dateValue, 'GMT+03', 'dd.MM.yyyy')
        : dateValue;
      
      const orderInfo = {
        category: String(row[ONLINER_CONFIG.SHEET_COLUMNS.CATEGORY] || '').trim(), // Столбец J
        model: String(row[ONLINER_CONFIG.SHEET_COLUMNS.MODEL] || '').trim(),
        price: parsePrice(row[ONLINER_CONFIG.SHEET_COLUMNS.FINAL_PRICE]),
        address: String(row[ONLINER_CONFIG.SHEET_COLUMNS.CLIENT_ADDRESS] || '').trim(),
        payment: String(row[ONLINER_CONFIG.SHEET_COLUMNS.PAYMENT_TYPE] || '').trim(),
        deliveryDate: deliveryDate || ''
      };
      
      if (!ordersMap[phone]) {
        ordersMap[phone] = {
          categories: orderInfo.category ? [orderInfo.category] : [],
          models: [orderInfo.model],
          totalPrice: orderInfo.price,
          address: orderInfo.address,
          phone: phone,
          payments: orderInfo.payment ? [orderInfo.payment] : [],
          deliveryDate: orderInfo.deliveryDate
        };
      } else {
        // Добавляем категорию, если её ещё нет в списке для этого клиента
        if (orderInfo.category && !ordersMap[phone].categories.includes(orderInfo.category)) {
          ordersMap[phone].categories.push(orderInfo.category);
        }
        
        ordersMap[phone].models.push(orderInfo.model);
        ordersMap[phone].totalPrice += orderInfo.price;
        
        if (orderInfo.payment && !ordersMap[phone].payments.includes(orderInfo.payment)) {
          ordersMap[phone].payments.push(orderInfo.payment);
        }
        
        if (orderInfo.deliveryDate && !ordersMap[phone].deliveryDate) {
          ordersMap[phone].deliveryDate = orderInfo.deliveryDate;
        }
      }
    }
    
    if (Object.keys(ordersMap).length === 0) {
      ui.alert('❌ Нет данных');
      return;
    }
    
    showOrdersInfoDialog(ordersMap);
    
  } catch (error) {
    const ui = SpreadsheetApp.getUi();
    ui.alert('Ошибка', `Ошибка отображения заказов: ${error.message}`, ui.ButtonSet.OK);
    Logger.error('Ошибка в showSelectedOrdersInfo:', error);
  }
}

