/**
 * Универсальная функция для вставки данных (PRODUCTION-READY ВЕРСИЯ)
 * Оптимальная стратегия: 1 чтение + 1 запись
 */

/**
 * Получение данных заказа с Onliner (API)
 */
function fetchOrderData(orderCode, token) {
  const url = `${ONLINER_CONFIG.API.BASE_URL}/orders/${orderCode}?include=positions`;

  const response = UrlFetchApp.fetch(url, {
    method: 'get',
    headers: {
      Accept: 'application/json; charset=utf-8',
      Authorization: `Bearer ${token}`
    },
    muteHttpExceptions: true
  });

  const code = response.getResponseCode();
  if (code !== 200) {
    throw new Error(`Onliner API error ${code}: ${response.getContentText()}`);
  }

  return JSON.parse(response.getContentText());
}

/**
 * Универсальная функция для вставки данных (PRODUCTION-READY ВЕРСИЯ)
 * Оптимальная стратегия: 1 чтение + 1 запись
 */
function insertDataOptimized(sheet, positions, order, source, paymentType, startRow) {
  const cols = {
    1:  [], // A статус - ДОБАВЛЕНО
    5:  [], // E номер заказа
    9:  [], // I источник
    12: [], // L модель
    14: [], // N ФИО
    15: [], // O телефон
    16: [], // P адрес
    17: [], // Q оплата
    20: [], // T цена позиции
    21: [], // U доставка
    35: []  // AH гарантия
  };

  positions.forEach(p => {
    const delivery = order.delivery?.price?.amount
      ? order.delivery.price.amount.replace('.', ',')
      : '0,00';

    cols[1].push(['Заказан']);  // 👈 СТОЛБЕЦ A - СТАТУС
    cols[5].push([order.key]);
    cols[9].push([source]);
    cols[12].push([p.product.full_name]);
    cols[14].push([order.contact.name]);
    cols[15].push([order.contact.phone]);
    cols[16].push([`${order.delivery.city}, ${order.delivery.address}`]);
    cols[17].push([paymentType]);
    cols[20].push([p.position_price.amount.replace('.', ',')]);
    cols[21].push([delivery]);
    cols[35].push([p.warranty]);
  });

  writeColumnsSafe(sheet, startRow, cols);

  return {
    positionsCount: positions.length,
    startRow,
    endRow: startRow + positions.length - 1,
    orderNumber: order.key
  };
}

/**
 * Вставка данных в текущую позицию курсора (ФИНАЛЬНАЯ ВЕРСИЯ)
 */
function insertAtActiveCell(order, source) {
  const sheet = SpreadsheetApp.getActiveSheet();
  
  // Защита от выбора заголовка или пустой строки
  const activeRow = sheet.getActiveCell().getRow();
  const startRow = Math.max(activeRow, 2); // Не позволяем вставлять выше строки 2
  
  const paymentType = ONLINER_CONFIG.PAYMENT_METHODS[order.payment?.type] || 
                     ONLINER_CONFIG.PAYMENT_METHODS.default;

  const positions = order.positions || [];
  if (!positions.length) {
    throw new Error('В заказе нет позиций');
  }

  // Используем оптимизированную версию
  return insertDataOptimized(sheet, positions, order, source, paymentType, startRow);
}

/**
 * Добавление заказа в конец таблицы (ФИНАЛЬНАЯ ВЕРСИЯ)
 */
function insertOrderAtEnd(order, source) {
  const sheet = SpreadsheetApp.getActiveSheet();
  const lastRow = Math.max(sheet.getLastRow(), 1); // Минимум строка 1
  const startRow = lastRow + 1;

  const paymentType = ONLINER_CONFIG.PAYMENT_METHODS[order.payment?.type] || 
                     ONLINER_CONFIG.PAYMENT_METHODS.default;

  const positions = order.positions || [];
  if (!positions.length) {
    throw new Error('В заказе нет позиций');
  }

  // Используем оптимизированную версию
  return insertDataOptimized(sheet, positions, order, source, paymentType, startRow);
}

/**
 * Получение данных заказа с Onliner (универсальная функция) - ИСПРАВЛЕННАЯ
 */
function getOnlinerOrder(clientType, orderCode, options = {}) {
  const defaults = {
    insertMode: 'activeCell',  // 'activeCell' | 'append' | 'replace'
    showAlert: true,
    optimized: true  // Использовать оптимизированную версию (реально работает)
  };
  const settings = { ...defaults, ...options };
  
  try {
    const token = getOnlinerToken(clientType);
    const orderData = fetchOrderData(orderCode, token);
    
    let result;
    const sourceName = `Корзина ${clientType.toLowerCase()}(o)`;
    
    switch (settings.insertMode) {
      case 'append':
        result = insertOrderAtEnd(orderData, sourceName);
        break;
      case 'replace':
        result = replaceCurrentRange(orderData, sourceName);
        break;
      case 'activeCell':
      default:
        result = insertAtActiveCell(orderData, sourceName);
        break;
    }
    
    if (settings.showAlert) {
      showSuccessAlert(result.positionsCount, clientType);
    }
    
    return result;
    
  } catch (error) {
    Logger.error('Ошибка получения заказа %s (%s): %s', clientType, orderCode, error.message);
    
    if (settings.showAlert) {
      showErrorAlert(`Не удалось загрузить заказ ${clientType}: ${error.message}`);
    }
    
    throw error;
  }
}

/**
 * Замена текущего выделенного диапазона (ОПТИМИЗИРОВАННАЯ ВЕРСИЯ)
 */
function replaceCurrentRange(order, source) {
  const sheet = SpreadsheetApp.getActiveSheet();
  const selection = sheet.getActiveRange();
  
  if (!selection) {
    throw new Error('Не выделен диапазон для замены');
  }

  const startRow = selection.getRow();
  const rowCount = selection.getNumRows();
  const positions = order.positions || [];
  
  if (positions.length > rowCount) {
    throw new Error(`Выделено ${rowCount} строк, но в заказе ${positions.length} позиций`);
  }

  const paymentType = ONLINER_CONFIG.PAYMENT_METHODS[order.payment?.type] || 
                     ONLINER_CONFIG.PAYMENT_METHODS.default;

  if (rowCount > positions.length) {
    sheet
      .getRange(startRow + positions.length, 1, rowCount - positions.length, sheet.getLastColumn())
      .clearContent();
  }

  return insertDataOptimized(
    sheet,
    positions,
    order,
    source,
    paymentType,
    startRow
  );
}
