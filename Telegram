function saveDeliveryPayments(data) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Заказы');

  data.forEach(item => {
    sheet.getRange(item.row, 25).setValue(item.value); 
    // 25 = столбец Y
  });
}


function writeColumnsSafe(sheet, startRow, columnMap) {
  const rowsNeeded = Object.values(columnMap)[0].length;
  const lastRow = sheet.getLastRow();

  if (startRow + rowsNeeded - 1 > lastRow) {
    sheet.insertRowsAfter(lastRow, startRow + rowsNeeded - 1 - lastRow);
  }

  Object.entries(columnMap).forEach(([col, values]) => {
    sheet
      .getRange(startRow, Number(col), values.length, 1)
      .setValues(values);
  });
}

