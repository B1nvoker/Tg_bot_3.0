/**
 * Замена текста в элементах документа
 */
function replaceInDocumentElement(element, replacements) {
  const elementType = element.getType();
  
  if (elementType === DocumentApp.ElementType.PARAGRAPH) {
    const paragraph = element.asParagraph();
    Object.keys(replacements).forEach(key => {
      const pattern = key.replace(/[{}]/g, '\\$&');
      paragraph.replaceText(pattern, String(replacements[key]));
    });
    return;
  }
  
  if (elementType === DocumentApp.ElementType.TABLE) {
    const table = element.asTable();
    for (let row = 0; row < table.getNumRows(); row++) {
      const tableRow = table.getRow(row);
      for (let cell = 0; cell < tableRow.getNumCells(); cell++) {
        const tableCell = tableRow.getCell(cell);
        for (let i = 0; i < tableCell.getNumChildren(); i++) {
          const child = tableCell.getChild(i);
          if (child.getType() === DocumentApp.ElementType.PARAGRAPH) {
            replaceInDocumentElement(child, replacements);
          }
        }
      }
    }
  }
}

/**
 * Копирование и обработка шаблонов
 */
function copyAndProcessTemplate(templateId, folderId, fileName) {
  const templateFile = DriveApp.getFileById(templateId);
  const tempFolder = DriveApp.getFolderById(folderId);
  
  const tempFile = templateFile.makeCopy(fileName, tempFolder);
  const tempDoc = DocumentApp.openById(tempFile.getId());
  
  return { file: tempFile, doc: tempDoc };
}
/**
 * Создание печатных документов (С УМНОЙ ПОДСТАНОВКОЙ ГАРАНТИИ И ПРАВИЛЬНЫМ СКЛОНЕНИЕМ)
 */
function createPrintDocuments() {
  try {
    const ui = SpreadsheetApp.getUi();
    
    const templates = {
      TUF: DocumentApp.openById(ONLINER_CONFIG.TEMPLATES.TUF),
      INOTE: DocumentApp.openById(ONLINER_CONFIG.TEMPLATES.INOTE)
    };
    
    const folder = DriveApp.getFolderById(ONLINER_CONFIG.FOLDERS.TEMP);
    const today = Utilities.formatDate(new Date(), 'GMT+03', 'dd.MM.yyyy');
    const fileName = `Документы ${today}`;
    
    const { file: mergedFile, doc: mergedDoc } = copyAndProcessTemplate(
      ONLINER_CONFIG.TEMPLATES.INOTE,
      ONLINER_CONFIG.FOLDERS.TEMP,
      fileName
    );
    
    const body = mergedDoc.getBody();
    body.clear();
    
    const sheet = SpreadsheetApp.getActiveSheet();
    const selectedRange = sheet.getActiveRange();
    
    if (!selectedRange) {
      ui.alert('Ошибка', 'Не выделен диапазон данных.', ui.ButtonSet.OK);
      return;
    }
    
    const rows = selectedRange.getValues();
    const modelsSummary = [];
    
    rows.forEach((row, index) => {
      const isTufSource = String(row[ONLINER_CONFIG.SHEET_COLUMNS.SOURCE] || '')
        .toLowerCase()
        .includes('tuf');
      
      const templateDoc = isTufSource ? templates.TUF : templates.INOTE;
      const templateBody = templateDoc.getBody();
      
      const startIndex = body.getNumChildren();
      
      for (let i = 0; i < templateBody.getNumChildren(); i++) {
        const element = templateBody.getChild(i).copy();
        const elementType = element.getType();
        
        switch (elementType) {
          case DocumentApp.ElementType.PARAGRAPH:
            body.appendParagraph(element.asParagraph());
            break;

          case DocumentApp.ElementType.TABLE:
            body.appendTable(element.asTable());
            break;

          case DocumentApp.ElementType.INLINE_IMAGE:
            body.appendImage(element.asInlineImage());
            break;

          case DocumentApp.ElementType.LIST_ITEM:
            body.appendListItem(element.asListItem());
            break;

          default:
            // ⚠️ безопасный fallback
            body.appendParagraph(element.getText ? element.getText() : '');
        }
      }
      
      const endIndex = body.getNumChildren() - 1;
      
      const dateValue = row[ONLINER_CONFIG.SHEET_COLUMNS.DATE_DELIVERY];
      const deliveryDate = dateValue instanceof Date
        ? Utilities.formatDate(dateValue, 'GMT+03', 'dd.MM.yyyy')
        : dateValue;
      
      // УМНАЯ ПОДСТАНОВКА ГАРАНТИИ С ПРАВИЛЬНЫМ СКЛОНЕНИЕМ
      const acValue = parseInt(row[ONLINER_CONFIG.SHEET_COLUMNS.WARRANTY_BASE], 10);
      const aiValue = parseInt(row[ONLINER_CONFIG.SHEET_COLUMNS.WARRANTY_FULL], 10);

      let warrantyText = '';

      function plural(m) {
        return pluralizeMonths(m);
      }

      function buildFromAC(value) {
        if (isNaN(value) || value <= 0) {
          return null;
        }

        if (value < 36) {
          const serviceMonths = 36 - value;
          return `${value} ${plural(value)} + ${serviceMonths} ${plural(serviceMonths)} сервисного обслуживания`;
        }

        return `${value} ${plural(value)}`;
      }

      function buildFromAI(value) {
        if (isNaN(value) || value <= 0) {
          return null;
        }

        const base = 12;
        const serviceMonths = Math.max(value - base, 0);

        return serviceMonths > 0
          ? `${base} ${plural(base)} + ${serviceMonths} ${plural(serviceMonths)} сервисного обслуживания`
          : `${base} ${plural(base)}`;
      }

      // 🔥 ПРИОРИТЕТ ЛОГИКИ
      if (!isNaN(acValue) && acValue > 0) {
        warrantyText = buildFromAC(acValue);
      } 
      else if (!isNaN(aiValue) && aiValue > 0) {
        warrantyText = buildFromAI(aiValue);
      } 
      else {
        // ❗ вообще ничего не указано
        warrantyText = `12 ${plural(12)} + 24 ${plural(24)} сервисного обслуживания`;
      }
      
      const replacements = {
        '{Дата}': deliveryDate,
        '{Модель}': row[ONLINER_CONFIG.SHEET_COLUMNS.MODEL] || '',
        '{Цена продажи}': formatBYN(parsePrice(row[ONLINER_CONFIG.SHEET_COLUMNS.SALE_PRICE]), ' '),
        '{Гарантия}': warrantyText,
        '{Номер заказа}': row[ONLINER_CONFIG.SHEET_COLUMNS.ORDER_NUMBER] || ''
      };
      
      for (let i = startIndex; i <= endIndex; i++) {
        replaceInDocumentElement(body.getChild(i), replacements);
      }
      
      const finalPrice = parsePrice(row[ONLINER_CONFIG.SHEET_COLUMNS.FINAL_PRICE]);
      modelsSummary.push({
        model: row[ONLINER_CONFIG.SHEET_COLUMNS.MODEL] || '',
        price: finalPrice,
        formattedPrice: formatBYN(finalPrice, ' ')
      });
      
      if (index < rows.length - 1) {
        body.appendPageBreak();
      }
    });
    
    mergedDoc.saveAndClose();
    
    Object.values(templates).forEach(doc => doc.saveAndClose());
    
    showPrintResults(mergedDoc.getUrl(), modelsSummary);
    
  } catch (error) {
    const ui = SpreadsheetApp.getUi();
    ui.alert('Ошибка', `❗ ${error.message}`, ui.ButtonSet.OK);
    throw error;
  }
}

/**
 * Отображение результатов печати
 */
function showPrintResults(documentUrl, modelsSummary) {
  modelsSummary.sort((a, b) => a.price - b.price);
  
  const summaryHtml = `
    <table style="width:100%; border-collapse: collapse;">
      ${modelsSummary.map(item => `
        <tr>
          <td>${item.model}</td>
          <td style="text-align:right">
            <span style="white-space:nowrap">
              ${item.formattedPrice}
            </span>
