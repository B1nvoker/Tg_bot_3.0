/**
 * Форматирование суммы в BYN
 */
function formatBYN(value, separator = ' ') {
  const amount = typeof value === 'string' 
    ? parsePrice(value)
    : Number(value);
  
  if (isNaN(amount) || amount == null) return '';
  
  const [integer, decimal] = Math.abs(amount).toFixed(2).split('.');
  const sign = amount < 0 ? '-' : '';
  
  const formattedInteger = integer
    .split('')
    .reverse()
    .join('')
    .replace(/(\d{3})(?=\d)/g, `$1${separator}`)
    .split('')
    .reverse()
    .join('');
  
  return `${sign}${formattedInteger},${decimal}`;
}

/**
 * Правильное склонение слова "месяц"
 */
function pluralizeMonths(n) {
  if (n % 10 === 1 && n % 100 !== 11) return 'месяц';
  if ([2,3,4].includes(n % 10) && ![12,13,14].includes(n % 100)) return 'месяца';
  return 'месяцев';
}

/**
 * Нормализация телефона
 */
function normalizePhone(phone) {
  if (!phone) return '';
  
  return String(phone)
    .replace(/^(\+375|375|80)/, '')
    .replace(/[^\d]/g, '')
    .substring(0, 9);
}

/**
 * Парсинг цены из строки
 */
function parsePrice(value) {
  return Number(
    String(value || '')
      .replace(/\u00A0/g, '')
      .replace(/\s/g, '')
      .replace(',', '.')
  ) || 0;
}

// ===================== КЭШИРОВАНИЕ ТОКЕНОВ =====================
const tokenCache = {};

/**
 * Получение токена с кэшированием
 */
function getCachedToken(clientType = 'TUF') {
  const cacheKey = `${clientType}_token`;
  const now = Date.now();
  
  // Проверяем наличие валидного токена в кэше (50 минут)
  if (tokenCache[cacheKey] && tokenCache[cacheKey].expires > now) {
    Logger.log(`Используем кэшированный токен для ${clientType}`);
    return tokenCache[cacheKey].token;
  }
  
  // Получаем новый токен
  const token = getOnlinerTokenRaw(clientType);
  
  // Сохраняем в кэш
  tokenCache[cacheKey] = {
    token: token,
    expires: now + (50 * 60 * 1000) // 50 минут
  };
  
  Logger.log(`Новый токен получен и кэширован для ${clientType}`);
  return token;
}

/**
 * Получение токена авторизации Onliner (базовая версия)
 */
function getOnlinerTokenRaw(clientType = 'TUF') {
  const authToken = ONLINER_CONFIG.API.CLIENT_TOKENS[clientType];
  if (!authToken) throw new Error(`Неизвестный тип клиента: ${clientType}`);
  
  try {
    const response = UrlFetchApp.fetch(ONLINER_CONFIG.API.AUTH_URL, {
      method: 'post',
      contentType: 'application/x-www-form-urlencoded',
      payload: 'grant_type=client_credentials',
      headers: {
        Accept: 'application/json',
        Authorization: `Basic ${authToken}`
      },
      muteHttpExceptions: true
    });
    
    const responseCode = response.getResponseCode();
    if (responseCode !== 200) {
      throw new Error(`Ошибка авторизации Onliner: код ${responseCode}`);
    }
    
    const data = JSON.parse(response.getContentText());
    return data.access_token;
  } catch (error) {
    Logger.error(`Ошибка получения токена для ${clientType}: %s`, error.message);
    throw error;
  }
}

/**
 * Получение токена авторизации Onliner (публичная функция с кэшем)
 */
function getOnlinerToken(clientType = 'TUF') {
  return getCachedToken(clientType);
}

