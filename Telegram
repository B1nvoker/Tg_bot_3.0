/**
 * Отправка заказов во внешнюю систему (с обработкой ошибок)
 */
function sendOrdersToExternalSystem() {
  try {
    const fourteenDaysAgo = new Date(Date.now() - 1000 * 60 * 60 * 24 * 14);
    const sheet = SpreadsheetApp.getActiveSheet();
    const allData = sheet.getDataRange().getValues();
    
    const filteredData = allData.filter(row => {
      return row[ONLINER_CONFIG.SHEET_COLUMNS.STATUS] &&
             row[ONLINER_CONFIG.SHEET_COLUMNS.DATE_ORDER] &&
             row[ONLINER_CONFIG.SHEET_COLUMNS.DATE_SUPPLIER] &&
             row[ONLINER_CONFIG.SHEET_COLUMNS.DATE_DELIVERY] &&
             row[ONLINER_CONFIG.SHEET_COLUMNS.DATE_ORDER] > fourteenDaysAgo;
    });
    
    const orders = filteredData.map(row => ({
      Status: row[ONLINER_CONFIG.SHEET_COLUMNS.STATUS],
      DateOrder: Utilities.formatDate(row[ONLINER_CONFIG.SHEET_COLUMNS.DATE_ORDER], 'GMT+03', 'MM.dd.yyyy'),
      DateSupplier: Utilities.formatDate(row[ONLINER_CONFIG.SHEET_COLUMNS.DATE_SUPPLIER], 'GMT+03', 'MM.dd.yyyy'),
      DateDelivery: Utilities.formatDate(row[ONLINER_CONFIG.SHEET_COLUMNS.DATE_DELIVERY], 'GMT+03', 'MM.dd.yyyy'),
      NumberOrder: row[ONLINER_CONFIG.SHEET_COLUMNS.ORDER_NUMBER],
      Category: row[ONLINER_CONFIG.SHEET_COLUMNS.CATEGORY],
      Product: row[ONLINER_CONFIG.SHEET_COLUMNS.MODEL],
      PriceSupplier: row[ONLINER_CONFIG.SHEET_COLUMNS.SUPPLIER_PRICE_BYN],
      PriceOrder: row[ONLINER_CONFIG.SHEET_COLUMNS.SALE_PRICE],
      PriceDelivery: row[ONLINER_CONFIG.SHEET_COLUMNS.DELIVERY_PRICE],
      PriceOther: row[ONLINER_CONFIG.SHEET_COLUMNS.OTHER_PRICE],
      ClientName: row[ONLINER_CONFIG.SHEET_COLUMNS.CLIENT_NAME],
      ClientPhone: row[ONLINER_CONFIG.SHEET_COLUMNS.CLIENT_PHONE],
      ClientAddress: row[ONLINER_CONFIG.SHEET_COLUMNS.CLIENT_ADDRESS],
      SupplierName: row[ONLINER_CONFIG.SHEET_COLUMNS.SUPPLIER],
      DeliveryType: row[ONLINER_CONFIG.SHEET_COLUMNS.DELIVERY_TYPE],
      PaymentType: row[ONLINER_CONFIG.SHEET_COLUMNS.PAYMENT_TYPE],
      PricePaymentDelivery: row[ONLINER_CONFIG.SHEET_COLUMNS.DELIVERY_PAYMENT_PRICE],
      Comment: row[ONLINER_CONFIG.SHEET_COLUMNS.COMMENT]
    }));
    
    if (orders.length === 0) {
      SpreadsheetApp.getUi().alert('Информация', 'Нет данных для отправки.', SpreadsheetApp.getUi().ButtonSet.OK);
      return;
    }
    
    const apiUrl = 'https://b2c-inote.ru/api/order/PostOrderGoogleSheets';
    const payload = JSON.stringify(orders);
    
    const response = UrlFetchApp.fetch(apiUrl, {
      method: 'POST',
      contentType: 'application/json',
      headers: {
        Accept: 'application/json',
        'Content-Type': 'application/json'
      },
      payload: payload,
      muteHttpExceptions: true
    });
    
    const responseCode = response.getResponseCode();
    if (responseCode >= 200 && responseCode < 300) {
      SpreadsheetApp.getUi().alert('Успешно', `Отправлено ${orders.length} заказов.`, SpreadsheetApp.getUi().ButtonSet.OK);
    } else {
      throw new Error(`Ошибка API: код ${responseCode}, ответ: ${response.getContentText()}`);
    }
    
  } catch (error) {
    const ui = SpreadsheetApp.getUi();
    ui.alert('Ошибка отправки', `❗ ${error.message}`, ui.ButtonSet.OK);
    Logger.error('Ошибка в sendOrdersToExternalSystem:', error);
  }
}

// ===================== ПЕРЕМЕЩЕНИЕ ДАННЫХ МЕЖДУ ТАБЛИЦАМИ =====================

/**
 * Перенос данных между таблицами (ОПТИМИЗИРОВАННАЯ ВЕРСИЯ)
 */
function transferDataBetweenSheets() {
  try {
    const sourceSpreadsheet = SpreadsheetApp.openById(ONLINER_CONFIG.SPREADSHEETS.SOURCE);
    const targetSpreadsheet = SpreadsheetApp.openById(ONLINER_CONFIG.SPREADSHEETS.TARGET);
    
    const sourceSheet = sourceSpreadsheet.getSheets()[0];
    const targetSheet = targetSpreadsheet.getSheets()[0];
    
    // Определяем столбцы для переноса
    const sourceColumns = [4, 5, 17, 18, 22, 23, 24, 25]; // D, E, Q, R, V, W, X, Y
    
    // ЧИТАЕМ ВСЕ ДАННЫЕ ОДНИМ ВЫЗОВОМ
    const lastRow = sourceSheet.getLastRow();
    if (lastRow <= 1) {
      SpreadsheetApp.getUi().alert('Информация', 'В исходной таблице нет данных.', SpreadsheetApp.getUi().ButtonSet.OK);
      return;
    }
    
    // Получаем все данные из нужных колонок за один раз
    const allData = [];
    for (let col of sourceColumns) {
      const columnData = sourceSheet.getRange(2, col, lastRow - 1, 1).getValues();
      allData.push(columnData);
    }
    
    // Формируем комбинированные строки
    const combinedData = [];
    for (let i = 0; i < lastRow - 1; i++) {
      const row = [];
      for (let j = 0; j < sourceColumns.length; j++) {
        row.push(allData[j][i][0]);
      }
      combinedData.push(row);
    }
    
    // Очищаем целевую область и записываем данные
    const targetLastRow = targetSheet.getLastRow();
    if (targetLastRow > 1) {
      targetSheet.getRange(2, 1, targetLastRow - 1, sourceColumns.length).clearContent();
    }
    
    if (combinedData.length > 0) {
      targetSheet.getRange(2, 1, combinedData.length, combinedData[0].length)
        .setValues(combinedData);
      
      SpreadsheetApp.getUi().alert('Успешно', `Перенесено ${combinedData.length} строк.`, SpreadsheetApp.getUi().ButtonSet.OK);
    }
    
  } catch (error) {
    const ui = SpreadsheetApp.getUi();
    ui.alert('Ошибка', `Ошибка переноса данных: ${error.message}`, ui.ButtonSet.OK);
    Logger.error('Ошибка в transferDataBetweenSheets:', error);
  }
}

/**
 * Копирование заказов в лист гарантий
 */
function copyOrdersToWarrantySheet() {
  try {
    const spreadsheet = SpreadsheetApp.getActiveSpreadsheet();
    const sourceSheet = spreadsheet.getSheetByName('Заказы');
    const targetSheet = spreadsheet.getSheetByName('Гарантии');
    
    if (!sourceSheet || !targetSheet) {
      SpreadsheetApp.getUi().alert('Ошибка', 'Лист "Заказы" или "Гарантии" не найден.', SpreadsheetApp.getUi().ButtonSet.OK);
      return;
    }
    
    const selectedRange = sourceSheet.getActiveRange();
    if (!selectedRange) {
      SpreadsheetApp.getUi().alert('Ошибка', 'Не выделен диапазон данных.', SpreadsheetApp.getUi().ButtonSet.OK);
      return;
    }
    
    const data = selectedRange.getValues();
    if (data.length === 0) {
      SpreadsheetApp.getUi().alert('Информация', 'Нет данных для копирования.', SpreadsheetApp.getUi().ButtonSet.OK);
      return;
    }
    
    const formattedData = data.map(row => [
      row[ONLINER_CONFIG.SHEET_COLUMNS.DATE_DELIVERY],
      row[ONLINER_CONFIG.SHEET_COLUMNS.ORDER_NUMBER],
      `Категория: ${row[ONLINER_CONFIG.SHEET_COLUMNS.CATEGORY] || ''}
       Модель: ${row[ONLINER_CONFIG.SHEET_COLUMNS.MODEL] || ''}
       Цена: ${row[ONLINER_CONFIG.SHEET_COLUMNS.SALE_PRICE] || ''}`.trim(),
      row[ONLINER_CONFIG.SHEET_COLUMNS.SUPPLIER],
      `ФИО: ${row[ONLINER_CONFIG.SHEET_COLUMNS.CLIENT_NAME] || ''}
       Тел.: ${row[ONLINER_CONFIG.SHEET_COLUMNS.CLIENT_PHONE] || ''}
       Адрес: ${row[ONLINER_CONFIG.SHEET_COLUMNS.CLIENT_ADDRESS] || ''}`.trim()
    ]);
    
    const lastRow = targetSheet.getLastRow() + 1;
    targetSheet.getRange(lastRow, 2, formattedData.length, formattedData[0].length)
      .setValues(formattedData);
    
    SpreadsheetApp.getUi().alert('Успешно', `Скопировано ${formattedData.length} строк в гарантии.`, SpreadsheetApp.getUi().ButtonSet.OK);
    
  } catch (error) {
    const ui = SpreadsheetApp.getUi();
    ui.alert('Ошибка', `Ошибка копирования: ${error.message}`, ui.ButtonSet.OK);
    Logger.error('Ошибка в copyOrdersToWarrantySheet:', error);
  }
}

